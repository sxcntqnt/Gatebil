# =========================================================
# Server
# =========================================================

# Uvicorn listen port
PORT=5000

# Uvicorn worker processes
# Keep at 1 on GPU systems since models are not fork-safe
WORKERS=1

# Logging level
# Use "debug" to enable Swagger docs and verbose logging
LOG_LEVEL=info


# =========================================================
# Model Paths
# =========================================================

# DSNT TensorFlow frozen graph
FROZEN_MODEL_PATH=model/frozen_model.pb

# dlib 68-point facial landmark predictor
SHAPE_PREDICTOR_PATH=services/liveness_detection/landmarks/shape_predictor_68_face_landmarks.dat

# Emotion classifier weights
EMOTION_WEIGHTS_PATH=services/liveness_detection/landmarks/emotion_weights.pt


# =========================================================
# Runtime / Storage
# =========================================================

# Scratch directory for temporary/intermediate files
TMP_DIR=tmp


# =========================================================
# Face Verification
# =========================================================

# Cosine distance threshold for verification acceptance
FACE_VERIFICATION_THRESHOLD=0.6


# =========================================================
# Version Metadata
# =========================================================

# Returned in verification responses for auditing
MODEL_VERSION=vggface2-2026.05

# Liveness pipeline version
LIVENESS_VERSION=liveness-trinity-v2
