# ── Server ────────────────────────────────────────
PORT=8080
READ_TIMEOUT=10s
WRITE_TIMEOUT=30s
SHUTDOWN_TIMEOUT=15s

# ── KYC Inference Service ──────────────────────────
# The internal Python inference service that replaced Smile ID.
# Point at the Docker service name in compose, or a k3s ClusterIP in production.
KYC_SERVICE_URL=http://kyc-python:5000

# Per-request timeout to the Python service.
# Should be less than KYC_JOB_TIMEOUT to leave room for retry logic.
KYC_SERVICE_TIMEOUT=15s

# Max parallel in-flight calls to the Python service.
# Set equal to KYC_WORKER_COUNT unless the inference pod is GPU-constrained,
# in which case tune down to prevent CUDA contention (e.g. 4–8 on a single GPU).
KYC_SERVICE_CONCURRENCY=20

# ── PostgreSQL ────────────────────────────────────
DATABASE_DSN=postgres://kyc:kyc_secret@localhost:5432/kyc_db?sslmode=disable

# ── Redis (reserved for caching / rate-limiting) ──
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# ── Worker pool ───────────────────────────────────
KYC_WORKER_COUNT=20         # goroutines processing KYC jobs concurrently
KYC_QUEUE_DEPTH=500         # buffered channel size
KYC_MAX_RETRIES=3           # max hard retry attempts per job (backpressure retries are separate)
KYC_RETRY_BASE_DELAY=2s     # base for exponential backoff (2s → 4s → 8s)
KYC_JOB_TIMEOUT=30s         # per-job context deadline — must exceed KYC_SERVICE_TIMEOUT
