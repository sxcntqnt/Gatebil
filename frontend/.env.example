# ── Server ────────────────────────────────────────
PORT=8080
READ_TIMEOUT=10s
WRITE_TIMEOUT=30s
SHUTDOWN_TIMEOUT=15s

# ── Smile ID ──────────────────────────────────────
SMILE_ID_API_KEY=your_api_key_here
SMILE_ID_PARTNER_ID=your_partner_id_here
SMILE_ID_ENV=sandbox          # sandbox | production
SMILE_ID_TIMEOUT=20s

# ── PostgreSQL ────────────────────────────────────
DATABASE_DSN=postgres://kyc:kyc_secret@localhost:5432/kyc_db?sslmode=disable

# ── Redis (reserved for caching / dedup layer) ────
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# ── Worker pool ───────────────────────────────────
KYC_WORKER_COUNT=20         # goroutines processing KYC jobs concurrently
KYC_QUEUE_DEPTH=500         # buffered channel size
KYC_MAX_RETRIES=3           # max retry attempts per job
KYC_RETRY_BASE_DELAY=2s     # base for exponential backoff (2s, 4s, 8s…)
KYC_JOB_TIMEOUT=30s         # per-job context deadline (Smile ID SLA ≤ 500ms)
